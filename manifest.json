{
	"manifest_version": 3,
	"name": "GA4 Navigator",
	"version": "1.1",
	"description": "Jump to GA4 reports, see live metrics, manage multiple properties",
	"icons": {
		"16": "icons/icon16.svg",
		"32": "icons/icon32.svg",
		"48": "icons/icon48.svg",
		"128": "icons/icon128.svg"
	},
	"action": {
		"default_title": "GA4 Navigator",
		"default_icon": {
			"16": "icons/icon16.svg",
			"32": "icons/icon32.svg",
			"48": "icons/icon48.svg",
			"128": "icons/icon128.svg"
		}
	},
	"side_panel": {
		"default_path": "popup.html"
	},
	"background": {
		"service_worker": "background.js"
	},
	"permissions": [
		"identity",
		"sidePanel"
	],
	"host_permissions": [
		"https://analyticsdata.googleapis.com/*"
	],
	"oauth2": {
		"client_id": "442168594815-0rj9rl8i7m3tn4e1ibuckiv2vt8sf41r.apps.googleusercontent.com",
		"scopes": [
			"https://www.googleapis.com/auth/analytics.readonly"
		]
	}
}
